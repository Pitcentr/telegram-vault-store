# Telegram Bot Configuration
# Get token from @BotFather in Telegram
TG_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# PocketBase Configuration
# URL to PocketBase instance (default is fine for Umbrel)
PB_URL=http://pocketbase_server:8090

# PocketBase admin credentials (choose any email/password)
PB_ADMIN=admin@vault.local
PB_PASSWORD=SecurePassword123

# Master password for AES-256 encryption
# WARNING: If lost, all data will be unrecoverable!
# Use 32+ characters for maximum security
MASTER_PASSWORD=MyVeryLongAndSecureMasterPasswordForEncryption123456

# Allowed Telegram user IDs (comma-separated)
# Get your ID from @userinfobot in Telegram
ALLOWED_USERS=123456789,987654321