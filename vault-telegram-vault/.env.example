# Telegram Bot Token (get from @BotFather in Telegram)
# Example: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
APP_TG_TOKEN=

# PocketBase Admin Email
# Default: admin@vault.local
APP_PB_ADMIN=admin@vault.local

# PocketBase Admin Password (minimum 8 characters)
# Example: SecurePassword123
APP_PB_PASSWORD=

# Master Password for encryption (minimum 32 characters recommended)
# This is used to encrypt/decrypt all passwords
# Example: MyVeryLongAndSecureMasterPassword123456
APP_MASTER_PASSWORD=

# Allowed Telegram User IDs (comma-separated)
# Get your ID from @userinfobot in Telegram
# Example: 123456789,987654321
APP_ALLOWED_USERS=

# PocketBase URL (optional, default: http://pocketbase_server:8090)
# Only change if you have custom PocketBase installation
APP_POCKETBASE_URL=http://pocketbase_server:8090
